---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — Little Boogie Boy" description="Neem contact op met Little Boogie Boy voor boekingen en informatie.">

  <section class="relative h-64 flex items-end overflow-hidden pt-20">
    <div class="absolute inset-0">
      <img src="/images/concert4.jpg" alt="Contact" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-b from-dark/60 to-dark"></div>
    </div>
    <div class="relative z-10 px-6 pb-12 max-w-7xl mx-auto w-full">
      <span class="section-label">Bereikbaarheid</span>
      <h1 class="font-display text-5xl md:text-6xl text-cream">Contact</h1>
    </div>
  </section>

  <section class="py-20 px-6">
    <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-16">

      <!-- Info -->
      <div>
        <span class="section-label">Boekingen & info</span>
        <h2 class="font-display text-3xl text-cream mb-6">
          Interesse in een optreden?
        </h2>
        <p class="text-cream/60 leading-relaxed mb-8">
          Little Boogie Boy is beschikbaar voor festivals, café-concerten, theaterprogramma's en privé-evenementen.
          Neem gerust contact op voor beschikbaarheid en tarieven.
        </p>

        <div class="space-y-4 mb-10">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 border border-gold/30 flex items-center justify-center flex-none">
              <svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <a href="mailto:info@littleboogieboy.nl" class="text-cream/70 hover:text-gold transition-colors">
              info@littleboogieboy.nl
            </a>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 border border-gold/30 flex items-center justify-center flex-none">
              <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 24 24">
                <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
              </svg>
            </div>
            <a href="https://www.facebook.com/littleboogieboy" target="_blank" rel="noopener"
              class="text-cream/70 hover:text-gold transition-colors">
              Facebook
            </a>
          </div>
        </div>

        <div class="border border-white/10 p-6">
          <h3 class="font-display text-xl text-cream mb-3">Mogelijkheden</h3>
          <ul class="space-y-2 text-cream/60 text-sm">
            {['Café-concerten & festivals', 'Theater & zaaloptredens', 'Privé-evenementen & jubilea',
              'Duo, trio of volledige band', 'LBB Solo-formaat beschikbaar'].map(item => (
              <li class="flex items-center gap-2">
                <span class="w-1 h-1 bg-gold rounded-full flex-none"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Form -->
      <div>
        <span class="section-label">Stuur een bericht</span>
        <form
          action="https://formspree.io/f/your-form-id"
          method="POST"
          class="space-y-5"
        >
          <div>
            <label class="block text-xs tracking-widest uppercase text-cream/50 mb-2" for="name">Naam</label>
            <input
              id="name" name="name" type="text" required
              class="w-full bg-dark-3 border border-white/10 px-4 py-3 text-cream placeholder-cream/20 focus:border-gold focus:outline-none transition-colors"
              placeholder="Jouw naam"
            />
          </div>
          <div>
            <label class="block text-xs tracking-widest uppercase text-cream/50 mb-2" for="email">E-mail</label>
            <input
              id="email" name="email" type="email" required
              class="w-full bg-dark-3 border border-white/10 px-4 py-3 text-cream placeholder-cream/20 focus:border-gold focus:outline-none transition-colors"
              placeholder="jouw@email.nl"
            />
          </div>
          <div>
            <label class="block text-xs tracking-widest uppercase text-cream/50 mb-2" for="subject">Onderwerp</label>
            <select id="subject" name="subject"
              class="w-full bg-dark-3 border border-white/10 px-4 py-3 text-cream focus:border-gold focus:outline-none transition-colors">
              <option>Boeking aanvragen</option>
              <option>Informatie over optreden</option>
              <option>Pers & media</option>
              <option>Anders</option>
            </select>
          </div>
          <div>
            <label class="block text-xs tracking-widest uppercase text-cream/50 mb-2" for="message">Bericht</label>
            <textarea
              id="message" name="message" rows="5" required
              class="w-full bg-dark-3 border border-white/10 px-4 py-3 text-cream placeholder-cream/20 focus:border-gold focus:outline-none transition-colors resize-none"
              placeholder="Jouw bericht…"
            ></textarea>
          </div>
          <button type="submit" class="btn-gold w-full text-center">Verstuur bericht</button>
        </form>
      </div>

    </div>
  </section>

</Layout>
