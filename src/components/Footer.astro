---
---
<footer class="border-t border-white/10 bg-dark-2 py-12 mt-20">
  <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-6">
    <div class="text-center md:text-left">
      <p class="font-display text-lg text-cream">Little Boogie Boy</p>
      <p class="text-cream-muted text-sm mt-1">Chicago Blues uit Nederland</p>
    </div>

    <nav class="flex items-center gap-6">
      <a href="/agenda" class="text-xs tracking-widest uppercase text-cream/50 hover:text-gold transition-colors">Agenda</a>
      <a href="/muziek" class="text-xs tracking-widest uppercase text-cream/50 hover:text-gold transition-colors">Muziek</a>
      <a href="/contact" class="text-xs tracking-widest uppercase text-cream/50 hover:text-gold transition-colors">Contact</a>
    </nav>

    <div class="flex items-center gap-4">
      <a href="https://www.facebook.com/littleboogieboy" target="_blank" rel="noopener"
        class="text-cream/40 hover:text-gold transition-colors" aria-label="Facebook">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
        </svg>
      </a>
      <a href="https://www.youtube.com/@littleboogieboy" target="_blank" rel="noopener"
        class="text-cream/40 hover:text-gold transition-colors" aria-label="YouTube">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M21.543 6.498C22 8.28 22 12 22 12s0 3.72-.457 5.502c-.254.985-.997 1.76-1.938 2.022C17.896 20 12 20 12 20s-5.893 0-7.605-.476c-.945-.266-1.687-1.04-1.938-2.022C2 15.72 2 12 2 12s0-3.72.457-5.502c.254-.985.997-1.76 1.938-2.022C6.107 4 12 4 12 4s5.896 0 7.605.476c.945.266 1.687 1.04 1.938 2.022zM10 15.5l6-3.5-6-3.5v7z"/>
        </svg>
      </a>
    </div>
  </div>
  <div class="max-w-7xl mx-auto px-6 mt-8 pt-6 border-t border-white/5">
    <p class="text-center text-cream/30 text-xs">© {new Date().getFullYear()} Little Boogie Boy — Hein Meijer</p>
  </div>
</footer>
